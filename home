<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>CUSCO THAILAND SPA EIRL</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet">

<style>

/* GENERAL */

body{
margin:0;
font-family:'Poppins', sans-serif;
color:white;
overflow-x:hidden;
}

/* FONDO */

.bg{
position:fixed;
width:100%;
height:100%;
background-size:cover;
background-position:center;
animation:fade 20s infinite;
}

.bg1{background-image:url("spa.jpg");animation-delay:0s;}
.bg2{background-image:url("jacuzzy.jpg");animation-delay:10s;}

@keyframes fade{
0%{opacity:1}
45%{opacity:1}
50%{opacity:0}
95%{opacity:0}
100%{opacity:1}
}

/* OVERLAY */

.overlay{
background:rgba(0,0,0,0.45);
min-height:100vh;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
padding:10px 40px;
background:white;
position:sticky;
top:0;
z-index:100;
}

.brand{
display:flex;
align-items:center;
gap:10px;
}

.brand img{
height:55px;
}

.logo-text{
font-family:'Playfair Display', serif;
font-size:22px;
color:#2f8f8f;
}

/* MENU */

.menu{
display:flex;
gap:25px;
}

.menu div{
cursor:pointer;
font-weight:500;
color:#333;
transition:.3s;
}

.menu div:hover{
color:#2f8f8f;
}

/* DATE */

.datetime{
color:#333;
font-size:14px;
}

/* USER */

.user{
background:#2f8f8f;
color:white;
padding:8px 12px;
border-radius:50%;
}

/* DASHBOARD */

.dashboard{
padding:40px;
text-align:center;
}

.dashboard h1{
font-size:38px;
margin-bottom:15px;
}

/* BOTON NUEVA RESERVA */

.btn-reserva{
background:#2f8f8f;
border:none;
padding:12px 20px;
border-radius:8px;
color:white;
cursor:pointer;
font-size:15px;
margin-bottom:35px;
transition:.3s;
}

.btn-reserva:hover{
background:#227373;
transform:scale(1.05);
}

/* TARJETAS ESTADISTICAS */

.stats{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
margin-bottom:40px;
}

.stat{
background:rgba(255,255,255,0.2);
backdrop-filter:blur(6px);
border-radius:12px;
padding:20px;
border:1px solid rgba(255,255,255,0.4);
transition:.3s;
}

.stat:hover{
transform:scale(1.05);
background:rgba(255,255,255,0.35);
}

.stat img{
width:40px;
margin-bottom:10px;
}

.stat span{
font-size:28px;
font-weight:bold;
}

/* RESERVAS */

.reservas{
background:rgba(255,255,255,0.2);
backdrop-filter:blur(6px);
padding:25px;
border-radius:12px;
border:1px solid rgba(255,255,255,0.4);
margin-bottom:40px;
}

.reserva-item{
display:flex;
justify-content:space-between;
padding:10px;
border-bottom:1px solid rgba(255,255,255,0.2);
}

/* MODULOS */

.modules{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
}

.module{
background:rgba(255,255,255,0.2);
backdrop-filter:blur(6px);
padding:25px;
border-radius:12px;
border:1px solid rgba(255,255,255,0.4);
cursor:pointer;
transition:.3s;
}

.module:hover{
transform:scale(1.05);
background:rgba(255,255,255,0.35);
}

.module img{
width:55px;
margin-bottom:10px;
}

</style>
</head>

<body>

<div class="bg bg1"></div>
<div class="bg bg2"></div>

<div class="overlay">

<header class="header">

<div class="brand">
<img src="logo.png">
<div class="logo-text">CUSCO THAILAND SPA</div>
</div>

<nav class="menu">
<div>Core</div>
<div>Logística</div>
<div>Ventas</div>
<div>Almacén</div>
</nav>

<div class="datetime" id="datetime"></div>

<div class="user">SS</div>

</header>

<section class="dashboard">

<h1 id="saludo"></h1>

<button class="btn-reserva">➕ Nueva Reserva</button>

<div class="stats">

<div class="stat">
<img src="https://cdn-icons-png.flaticon.com/512/747/747310.png">
<h4>Reservas</h4>
<span>12</span>
</div>

<div class="stat">
<img src="https://cdn-icons-png.flaticon.com/512/847/847969.png">
<h4>Clientes</h4>
<span>8</span>
</div>

<div class="stat">
<img src="https://cdn-icons-png.flaticon.com/512/1170/1170678.png">
<h4>Ventas</h4>
<span>S/520</span>
</div>

<div class="stat">
<img src="https://cdn-icons-png.flaticon.com/512/679/679922.png">
<h4>Stock</h4>
<span>3</span>
</div>

</div>

<div class="reservas">

<h2>Reservas de Hoy</h2>

<div class="reserva-item">
<span>10:00</span>
<span>Maria Lopez</span>
<span>Masaje</span>
</div>

<div class="reserva-item">
<span>11:30</span>
<span>Juan Perez</span>
<span>Jacuzzi</span>
</div>

<div class="reserva-item">
<span>14:00</span>
<span>Ana Torres</span>
<span>Terapia</span>
</div>

</div>

<div class="modules">

<div class="module">
<img src="https://cdn-icons-png.flaticon.com/512/1077/1077114.png">
<h3>Core</h3>
</div>

<div class="module">
<img src="https://cdn-icons-png.flaticon.com/512/2920/2920277.png">
<h3>Logística</h3>
</div>

<div class="module">
<img src="https://cdn-icons-png.flaticon.com/512/2331/2331970.png">
<h3>Ventas</h3>
</div>

<div class="module">
<img src="https://cdn-icons-png.flaticon.com/512/263/263142.png">
<h3>Almacén</h3>
</div>

</div>

</section>

</div>

